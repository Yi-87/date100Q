<view class="page">
  <view wx:if="{{reconcileNotice}}" class="reconcile-modal">
    <view class="reconcile-card">
      <text class="reconcile-title">TA 发起了强制解除</text>
      <text class="reconcile-desc">你的伴侣单方面解除了配对。如果这是一个误会，你可以选择和好；否则可以关闭通知。</text>
      <view class="reconcile-buttons">
        <button class="reconcile-accept" bindtap="onReconcileAccept">愿意和好</button>
        <button class="reconcile-reject" bindtap="onReconcileReject">关闭</button>
      </view>
    </view>
  </view>
  <view class="brand" wx:if="{{status !== 'loading' && status !== 'no_couple'}}">
    <text class="brand-name">恋爱100问</text>
    <text class="brand-slogan">每天一个问题，重新认识身边人</text>
  </view>
  <view wx:if="{{status === 'loading'}}" class="loading">
    <text class="loading-text">加载中...</text>
  </view>
  <view wx:elif="{{status === 'error'}}" class="error">
    <text class="error-text">加载失败</text>
    <button class="retry-btn" bindtap="onRetry">重试</button>
  </view>
  <view wx:elif="{{status === 'no_couple'}}" class="empty">
    <text class="empty-text">你还没和 TA 配对哦</text>
    <button class="pair-btn" bindtap="onGoPair">去配对</button>
  </view>
  <view wx:elif="{{status === 'l3_locked'}}" class="l3">
    <l3-gate questionId="{{question.question_id}}" readyOpenids="{{readyOpenids}}" myReady="{{myReady}}" bind:ready="onL3Ready" />
  </view>
  <view wx:elif="{{status === 'pending'}}" class="today">
    <question-card question="{{question}}" bind:start="onStartAnswer" bind:swap="onSwap" />
  </view>
  <view wx:elif="{{status === 'half_answered'}}" class="waiting">
    <waiting-card question="{{question}}" />
    <button class="test-partner-btn" bindtap="onTestPartnerAnswer">测试：模拟对方回答</button>
  </view>
  <view wx:elif="{{status === 'revealed'}}" class="revealed">
    <view class="reveal-card" wx:if="{{revealData}}">
      <text class="reveal-emoji">✨</text>
      <text class="reveal-title">答案揭晓</text>
      <text class="reveal-question">{{revealData.text}}</text>
      <view class="reveal-answers">
        <view class="reveal-answer-item reveal-anim-1">
          <text class="reveal-label">我</text>
          <text class="reveal-content">{{revealData.my_answer ? revealData.my_answer.content : '暂无答案'}}</text>
        </view>
        <view class="reveal-answer-item reveal-anim-2">
          <text class="reveal-label">TA</text>
          <text class="reveal-content">{{revealData.partner_answer ? revealData.partner_answer.content : '暂无答案'}}</text>
        </view>
      </view>
    </view>
    <button class="history-btn" bindtap="onGoHistory">查看历史记录</button>
  </view>
</view>