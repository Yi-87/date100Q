/* 历史页 — 我们的足迹 */

.page {
  padding: 0 40rpx 40rpx;
  min-height: 100vh;
}

/* 顶部 Tab */
.tabs {
  display: flex;
  gap: 8rpx;
  padding: 24rpx 0;
  position: sticky;
  top: 0;
  background: var(--bg);
  z-index: 10;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--text-sm);
  color: var(--muted);
  border-radius: var(--r-full);
  background: transparent;
}
.tab.active {
  color: var(--accent);
  font-weight: 600;
  background: var(--accent-lighter);
}

.loading {
  text-align: center;
  margin-top: 400rpx;
}
.loading-text {
  color: var(--muted);
  font-size: var(--text-base);
}
.error {
  text-align: center;
  margin-top: 400rpx;
}
.error-text {
  display: block;
  color: var(--error);
  font-size: var(--text-sm);
  margin-bottom: 32rpx;
}
.retry-btn {
  width: 240rpx;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--cta-bg);
  color: var(--cta-text);
  font-size: var(--text-sm);
  line-height: var(--cta-height);
}

/* 空状态 */
.empty {
  text-align: center;
  margin-top: 400rpx;
  color: var(--muted);
  font-size: var(--text-base);
}

/* 月份分组 */
.month-group {
  margin-bottom: 48rpx;
}
.month-label {
  display: block;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--muted);
  margin-bottom: 20rpx;
  padding-left: 8rpx;
  letter-spacing: 0.04em;
}

/* 历史卡片 */
.history-card {
  background: var(--bg-card);
  border-radius: var(--r-lg);
  padding: 36rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--rule);
  box-sizing: border-box;
}
.q-text {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--ink);
  display: block;
  margin-bottom: 28rpx;
  line-height: 1.3;
}
.answers {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.my {
  display: block;
  font-size: var(--text-sm);
  line-height: 1.6;
  color: var(--accent-dark);
  margin-bottom: 20rpx;
  padding-top: 0;
  border-top: none;
}
.partner {
  display: block;
  font-size: var(--text-sm);
  line-height: 1.6;
  color: var(--ink2);
  padding-top: 20rpx;
  margin-top: 0;
  border-top: 1rpx solid var(--rule);
}

/* 过往关系卡片 */
.past-couple-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--rule);
  border-radius: var(--r-lg);
  margin-bottom: 16rpx;
}
.past-couple-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
}
.past-couple-info {
  flex: 1;
}
.past-stage {
  display: block;
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 8rpx;
}
.past-date {
  display: block;
  font-size: var(--text-xs);
  color: var(--muted);
}
.past-arrow {
  font-size: var(--text-lg);
  color: var(--faint);
  margin-left: 16rpx;
}
.past-couple-actions {
  margin-left: 16rpx;
  padding-left: 16rpx;
  border-left: 1rpx solid var(--rule);
}
.past-delete-btn {
  font-size: var(--text-sm);
  color: var(--error);
  padding: 8rpx 16rpx;
}

.past-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0 32rpx;
  font-size: var(--text-sm);
  color: var(--muted);
}
.back-arrow {
  font-size: 36rpx;
  color: var(--muted);
}
.back-text {
  color: var(--muted);
}
.past-card {
  opacity: 0.85;
}

/* 删除确认弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-content {
  width: 600rpx;
  background: #ffffff;
  border-radius: var(--r-lg);
  padding: 40rpx;
}
.modal-title {
  display: block;
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--ink);
  text-align: center;
  margin-bottom: 24rpx;
}
.modal-desc {
  display: block;
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.6;
  text-align: center;
  margin-bottom: 40rpx;
}
.modal-buttons {
  display: flex;
  gap: 16rpx;
}
.modal-cancel-btn {
  flex: 1;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--bg2);
  color: var(--muted);
  font-size: var(--text-base);
  line-height: var(--cta-height);
  border: 1rpx solid var(--rule);
}
.modal-confirm-btn {
  flex: 1;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--error);
  color: #ffffff;
  font-size: var(--text-base);
  font-weight: 500;
  line-height: var(--cta-height);
}