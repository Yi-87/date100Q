.page {
  padding: 32rpx;
  min-height: 100vh;
}
.stage-section {
  margin-bottom: 64rpx;
}
.label {
  display: block;
  font-size: 28rpx;
  color: var(--muted);
  margin-bottom: 20rpx;
}
.stage-buttons {
  display: flex;
  gap: 16rpx;
}
.stage-buttons button {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 48rpx;
  background: var(--bg2);
  color: var(--muted);
  border: 1rpx solid var(--rule);
}
.stage-buttons button.active {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}
.danger {
  text-align: center;
}
.unbind-btn {
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
  border-radius: 48rpx;
  width: 300rpx;
}
.unbind-confirm {
  margin-top: 24rpx;
}
.unbind-confirm text {
  display: block;
  color: var(--accent);
  margin-bottom: 24rpx;
}
.confirm-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}
.confirm-buttons button {
  width: 200rpx;
  border-radius: 48rpx;
}
.confirm {
  background: var(--accent);
  color: #fff;
}