<view class="page">
  <view wx:if="{{errorMsg}}" class="error-msg">{{errorMsg}}</view>
  <view wx:if="{{role === 'none'}}" class="choose">
    <button class="choose-btn primary" bindtap="onCreateInvite">邀请 TA</button>
    <button class="choose-btn secondary" bindtap="onJoinMode">我有邀请码</button>
    <view class="test-section">
      <button class="test-btn" bindtap="onTestMockPair">测试模式：独自配对</button>
      <text class="test-hint">无需邀请人，模拟对方完成全流程</text>
    </view>
  </view>
  <view wx:elif="{{role === 'creator'}}" class="invite">
    <text class="invite-tip">把卡片分享给 TA，TA 点开即可加入</text>
    <text class="code">{{myCode}}</text>
    <text class="expiry">10 分钟内有效</text>
    <button class="share-btn" open-type="share">分享给 TA</button>
    <button class="copy-btn" bindtap="onCopy">复制邀请码</button>
  </view>
  <view wx:elif="{{role === 'joiner'}}" class="join">
    <view wx:if="{{autoJoining}}" class="auto-joining">
      <text class="joining-text">正在加入...</text>
    </view>
    <view wx:else>
      <input type="number" maxlength="6" placeholder="输入 6 位邀请码" bindinput="onCodeInput" value="{{inviteCode}}" />
      <button class="join-btn" bindtap="onJoin">加入</button>
    </view>
  </view>
</view>
