/* 首页 — 今日一问 */

.page {
  padding: 0 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 品牌区 */
.brand {
  text-align: center;
  margin-bottom: 48rpx;
}
.brand-name {
  display: block;
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.brand-slogan {
  display: block;
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: 2rpx;
}

/* 空状态：未配对 */
.empty {
  text-align: center;
}
.empty-text {
  display: block;
  margin-bottom: 64rpx;
  color: var(--muted);
  font-size: var(--text-xl);
}
.pair-btn {
  width: 400rpx;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--cta-bg);
  color: var(--cta-text);
  font-size: var(--text-base);
  font-weight: 500;
  line-height: var(--cta-height);
}

/* 加载 / 错误 */
.loading-text {
  color: var(--muted);
  font-size: var(--text-base);
}
.error {
  text-align: center;
}
.error-text {
  display: block;
  color: var(--error);
  font-size: var(--text-sm);
  margin-bottom: 32rpx;
}
.retry-btn {
  width: 240rpx;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--cta-bg);
  color: var(--cta-text);
  font-size: var(--text-sm);
  line-height: var(--cta-height);
}

/* 已揭晓卡片 */
.l3 {
  width: 100%;
}
.today {
  width: 100%;
}
.waiting {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.reveal-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--r-xl);
  padding: 56rpx 40rpx 48rpx;
  border: 1rpx solid var(--rule);
  box-sizing: border-box;
  margin-bottom: 48rpx;
  animation: revealCardIn 0.6s ease-out both;
}
.reveal-emoji {
  display: block;
  text-align: center;
  font-size: 80rpx;
  margin-bottom: 16rpx;
  animation: emojiPop 0.8s ease-out 0.2s both;
}
.reveal-title {
  display: block;
  text-align: center;
  font-size: var(--text-sm);
  color: var(--accent);
  letter-spacing: 8rpx;
  margin-bottom: 40rpx;
  animation: fadeIn 0.5s ease-out 0.4s both;
}
.reveal-question {
  display: block;
  font-size: var(--text-lg);
  font-weight: 600;
  line-height: 1.3;
  color: var(--ink);
  margin-bottom: 48rpx;
  animation: fadeIn 0.5s ease-out 0.6s both;
}
.reveal-answers {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.reveal-answer-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  opacity: 0;
}
.reveal-anim-1 {
  animation: slideUpFade 0.5s ease-out 0.9s both;
}
.reveal-anim-2 {
  animation: slideUpFade 0.5s ease-out 1.3s both;
}
.reveal-answer-item + .reveal-answer-item {
  padding-top: 20rpx;
  border-top: 1rpx solid var(--rule);
}
.reveal-label {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-xs);
  font-weight: 600;
}
.reveal-answer-item:first-child .reveal-label {
  background: var(--accent-lighter);
  color: var(--accent-dark);
}
.reveal-answer-item:last-child .reveal-label {
  background: var(--bg2);
  color: var(--ink2);
}
.reveal-content {
  font-size: var(--text-sm);
  line-height: 1.6;
  padding-top: 8rpx;
  flex: 1;
}
.reveal-answer-item:first-child .reveal-content {
  color: var(--accent-dark);
}
.reveal-answer-item:last-child .reveal-content {
  color: var(--ink2);
}

@keyframes revealCardIn {
  0% { opacity: 0; transform: scale(0.92) translateY(20rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes emojiPop {
  0% { opacity: 0; transform: scale(0.3); }
  60% { opacity: 1; transform: scale(1.2); }
  100% { opacity: 1; transform: scale(1); }
}
@keyframes fadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}
@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(16rpx); }
  100% { opacity: 1; transform: translateY(0); }
}
.history-btn {
  margin-top: 48rpx;
  width: 400rpx;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--cta-bg);
  color: var(--cta-text);
  font-size: var(--text-sm);
  line-height: var(--cta-height);
}
.test-partner-btn {
  margin-top: 48rpx;
  width: 400rpx;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--rule);
  color: var(--ink);
  font-size: var(--text-sm);
  line-height: var(--cta-height);
}

/* 和好通知弹窗 */
.reconcile-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.reconcile-card {
  width: 600rpx;
  background: #ffffff;
  border-radius: var(--r-lg);
  padding: 48rpx 40rpx;
}
.reconcile-title {
  display: block;
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--ink);
  text-align: center;
  margin-bottom: 24rpx;
}
.reconcile-desc {
  display: block;
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.6;
  text-align: center;
  margin-bottom: 40rpx;
}
.reconcile-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.reconcile-accept {
  width: 100%;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--accent);
  color: #ffffff;
  font-size: var(--text-base);
  font-weight: 500;
  line-height: var(--cta-height);
}
.reconcile-reject {
  width: 100%;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--bg2);
  color: var(--muted);
  font-size: var(--text-base);
  line-height: var(--cta-height);
  border: 1rpx solid var(--rule);
}