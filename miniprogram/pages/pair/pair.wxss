.page {
  padding: 32rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.choose button {
  margin: 24rpx 0;
  width: 400rpx;
  border-radius: 48rpx;
}
.choose button:first-child {
  background: var(--accent);
  color: #fff;
}
.code {
  font-size: 80rpx;
  font-weight: 700;
  letter-spacing: 16rpx;
  color: var(--ink);
  display: block;
  text-align: center;
}
.expiry {
  display: block;
  text-align: center;
  color: var(--muted);
  font-size: 26rpx;
  margin: 16rpx 0 48rpx;
}
.invite button, .join button {
  background: var(--accent);
  color: #fff;
  border-radius: 48rpx;
  width: 400rpx;
}
.join input {
  width: 400rpx;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--rule);
  border-radius: 16rpx;
  font-size: 36rpx;
  text-align: center;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}