/* 配对页 — 连接彼此 */

.page {
  padding: 0 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 错误提示 */
.error-msg {
  display: block;
  text-align: center;
  color: var(--error);
  font-size: var(--text-sm);
  margin-bottom: 32rpx;
}

/* 选择模式 */
.choose {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.choose-btn {
  width: 100%;
  max-width: 520rpx;
  height: var(--cta-height);
  border-radius: var(--r-full);
  font-size: var(--text-base);
  font-weight: 500;
  line-height: var(--cta-height);
  margin: 20rpx 0;
}
.choose-btn.primary {
  background: var(--cta-bg);
  color: var(--cta-text);
}
.choose-btn.secondary {
  background: var(--surface-warm-bg);
  color: var(--surface-warm-text);
  border: 1rpx solid var(--rule);
}
.test-section {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.test-btn {
  width: 100%;
  max-width: 520rpx;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: transparent;
  color: var(--faint);
  font-size: var(--text-xs);
  line-height: var(--cta-height);
}
.test-hint {
  display: block;
  margin-top: 16rpx;
  font-size: var(--text-xs);
  color: var(--faint);
}

/* 邀请码展示 */
.invite {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.invite-tip {
  display: block;
  text-align: center;
  color: var(--muted);
  font-size: var(--text-sm);
  margin-bottom: 24rpx;
  line-height: 1.5;
}
.code {
  font-size: 120rpx;
  font-weight: 700;
  letter-spacing: 24rpx;
  color: var(--ink);
  display: block;
  text-align: center;
  margin: 24rpx 0 16rpx;
}
.expiry {
  display: block;
  text-align: center;
  color: var(--muted);
  font-size: var(--text-sm);
  margin-bottom: 48rpx;
}
.share-btn {
  background: var(--cta-bg);
  color: var(--cta-text);
  border-radius: var(--r-full);
  width: 100%;
  max-width: 520rpx;
  height: var(--cta-height);
  font-size: var(--text-base);
  font-weight: 500;
  line-height: var(--cta-height);
  margin-bottom: 16rpx;
}
.copy-btn {
  background: transparent;
  color: var(--muted);
  border: 1rpx solid var(--rule);
  border-radius: var(--r-full);
  width: 100%;
  max-width: 520rpx;
  height: var(--cta-height);
  font-size: var(--text-base);
  line-height: var(--cta-height);
}
.auto-joining {
  padding: 80rpx 0;
  text-align: center;
}
.joining-text {
  color: var(--muted);
  font-size: var(--text-base);
}

/* 输入邀请码 */
.join {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.join input {
  width: 100%;
  max-width: 520rpx;
  height: 104rpx;
  padding: 0 32rpx;
  border: 2rpx solid var(--rule-strong);
  border-radius: var(--r-md);
  font-size: var(--text-2xl);
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  box-sizing: border-box;
  background: var(--bg-card);
  color: var(--ink);
}
.join-btn {
  background: var(--cta-bg);
  color: var(--cta-text);
  border-radius: var(--r-full);
  width: 100%;
  max-width: 520rpx;
  height: var(--cta-height);
  font-size: var(--text-base);
  font-weight: 500;
  line-height: var(--cta-height);
}