.page {
  padding: 32rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.empty {
  text-align: center;
}
.empty text {
  display: block;
  margin-bottom: 32rpx;
  color: var(--muted);
  font-size: 30rpx;
}
.loading text {
  color: var(--muted);
}