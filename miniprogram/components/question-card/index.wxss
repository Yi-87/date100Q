/* 问题卡片组件 */

.card {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--r-xl);
  padding: 56rpx 40rpx 40rpx;
  border: 1rpx solid var(--rule);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰条 */
.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: var(--accent);
  border-radius: var(--r-xl) var(--r-xl) 0 0;
}

.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.dimension {
  font-size: var(--text-xs);
  color: var(--muted);
  background: var(--bg2);
  padding: 4rpx 20rpx;
  border-radius: var(--r-full);
  line-height: 1.6;
}
.sensitivity {
  font-size: var(--text-xs);
  color: var(--warn);
  line-height: 1.6;
}

.question-text {
  display: block;
  font-size: var(--text-2xl);
  font-weight: 600;
  line-height: 1.3;
  color: var(--ink);
  margin-bottom: 56rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
}
.action-btn {
  flex: 1;
  height: var(--cta-height);
  border-radius: var(--r-full);
  font-size: var(--text-base);
  line-height: var(--cta-height);
}
.action-btn-primary {
  background: var(--cta-bg);
  color: var(--cta-text);
  font-weight: 500;
}
.swap {
  background: var(--surface-warm-bg);
  color: var(--surface-warm-text);
  border: 1rpx solid var(--rule);
  font-weight: 500;
}