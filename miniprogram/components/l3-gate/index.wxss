.gate {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  border: 1rpx solid var(--rule);
  box-sizing: border-box;
}
.icon text {
  font-size: 64rpx;
  display: block;
  margin-bottom: 24rpx;
}
.title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 12rpx;
}
.desc {
  display: block;
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 32rpx;
}
.status {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
  font-size: 26rpx;
  color: var(--muted);
}
.gate button {
  background: var(--accent);
  color: #fff;
  border-radius: 48rpx;
  width: 300rpx;
}
.waiting-text text {
  color: var(--muted);
  font-size: 26rpx;
}