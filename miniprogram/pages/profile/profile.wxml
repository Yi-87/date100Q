<view class="page">
  <view wx:if="{{loading}}" class="loading">
    <text class="loading-text">加载中...</text>
  </view>
  <view wx:else>
    <view class="brand-header">
      <text class="brand-title">恋爱100问</text>
    </view>
    <view class="pair-status">
      <view class="avatar">
        <text style="font-size: 36rpx;">♥</text>
      </view>
      <view class="pair-info">
        <text wx:if="{{paired}}" class="paired">已与 TA 配对</text>
        <text wx:else class="unpaired">未配对</text>
        <text wx:if="{{createdDate}}" class="pair-date">配对时间：{{createdDate}}</text>
      </view>
    </view>

    <view class="stage-section">
      <text class="label">当前阶段</text>
      <view class="stage-buttons">
        <button class="{{stage === 'love' ? 'active' : ''}}" data-stage="love" bindtap="onStageChange">恋爱版</button>
        <button class="{{stage === 'pre_marriage' ? 'active' : ''}}" data-stage="pre_marriage" bindtap="onStageChange">婚前版</button>
        <button class="{{stage === 'marriage' ? 'active' : ''}}" data-stage="marriage" bindtap="onStageChange">维护版</button>
      </view>
      <text class="stage-desc">{{stageDesc}}</text>
    </view>

    <view class="settings-card">
      <view class="settings-row" bindtap="onDifficultyClick">
        <text class="settings-label">问题难度</text>
        <view class="settings-right">
          <text class="settings-value">{{difficultyLabel}}</text>
          <text class="settings-arrow">›</text>
        </view>
      </view>
      <view class="settings-row">
        <text class="settings-label">每日提醒</text>
        <view class="settings-right">
          <view class="switch" bindtap="onReminderToggle">
            <view class="switch-track">
              <view class="switch-thumb {{reminderEnabled ? 'active' : ''}}"></view>
            </view>
          </view>
          <text class="settings-value">{{reminderEnabled ? '已开启' : '未开启'}}</text>
        </view>
      </view>
      <view class="settings-row">
        <text class="settings-label">L3 敏感问题</text>
        <view class="settings-right">
          <view class="switch" bindtap="onL3Toggle">
            <view class="switch-track">
              <view class="switch-thumb {{l3Enabled ? 'active' : ''}}"></view>
            </view>
          </view>
          <text class="settings-value">{{l3Enabled ? '已开启' : '未开启'}}</text>
        </view>
      </view>
    </view>

    <view class="settings-card">
      <view class="settings-row" bindtap="onGoPast">
        <text class="settings-label">过往关系</text>
        <view class="settings-right">
          <text class="settings-value">{{pastCount}} 段</text>
          <text class="settings-arrow">›</text>
        </view>
      </view>
    </view>

    <view wx:if="{{showDifficultyModal}}" class="modal-mask" bindtap="onDifficultyClose">
      <view class="modal-content" catchtap="">
        <text class="modal-title">选择问题难度</text>
        <view class="modal-options">
          <view wx:for="{{difficultyOptions}}" wx:key="value" 
                class="modal-option {{difficulty === item.value ? 'selected' : ''}}"
                bindtap="onDifficultySelect" data-value="{{item.value}}">
            <text>{{item.label}}</text>
            <text wx:if="{{difficulty === item.value}}" class="option-check">✓</text>
          </view>
        </view>
        <button class="modal-cancel" bindtap="onDifficultyClose">取消</button>
      </view>
    </view>

    <view class="danger">
      <button wx:if="{{!showUnbind}}" bindtap="onUnbind" class="unbind-btn">解除配对</button>
      <view wx:elif="{{unbindStep === 'choose'}}" class="unbind-options">
        <text class="unbind-title">选择解除方式</text>
        <view class="unbind-option" bindtap="onNegotiateUnbind">
          <view class="unbind-option-info">
            <text class="unbind-option-name">协商解除</text>
            <text class="unbind-option-desc">需要对方同意，立即生效</text>
          </view>
          <text class="settings-arrow">›</text>
        </view>
        <view class="unbind-option" bindtap="onForceUnbind">
          <view class="unbind-option-info">
            <text class="unbind-option-name">强制解除</text>
            <text class="unbind-option-desc">单方面生效，3天内不能配对新人</text>
          </view>
          <text class="settings-arrow">›</text>
        </view>
        <button class="unbind-cancel-btn" bindtap="onCancelUnbind">取消</button>
      </view>
      <view wx:elif="{{unbindStep === 'force_confirm'}}" class="unbind-confirm">
        <text class="unbind-warning-title">⚠️ 强制解除确认</text>
        <text class="unbind-warning-text">强制解除将立即生效，且未来3天内你无法配对新的人。对方会收到通知并可以选择和好。确定继续吗？</text>
        <view class="confirm-buttons">
          <button bindtap="onForceConfirm" class="confirm">确定强制解除</button>
          <button bindtap="onCancelUnbind">取消</button>
        </view>
      </view>
      <view wx:elif="{{unbindStep === 'negotiate_waiting'}}" class="unbind-confirm">
        <text class="unbind-info-text">已发起协商解除请求</text>
        <text class="unbind-info-desc">需要对方也同意后才会立即生效。在此之前你们的配对关系依然有效。</text>
        <button class="unbind-cancel-btn" bindtap="onCancelUnbind">关闭</button>
      </view>
      <text wx:if="{{!showUnbind}}" class="unbind-hint">解除后所有历史记录将保留，但需重新配对</text>
    </view>
  </view>
</view>