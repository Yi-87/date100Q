/* 个人页 — 我的 */

.page {
  padding: 40rpx;
  min-height: 100vh;
}

.brand-header {
  text-align: center;
  padding: 16rpx 0 32rpx;
}
.brand-title {
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 4rpx;
}

.loading {
  text-align: center;
  margin-top: 400rpx;
}
.loading-text {
  color: var(--muted);
  font-size: var(--text-base);
}

/* 配对状态 */
.pair-status {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  background: var(--bg2);
  border-radius: var(--r-lg);
  margin-bottom: 56rpx;
}
.pair-status .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--accent-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 36rpx;
}
.pair-info {
  flex: 1;
}
.paired {
  display: block;
  color: var(--ink);
  font-size: var(--text-base);
  font-weight: 600;
  margin-bottom: 4rpx;
}
.unpaired {
  display: block;
  color: var(--error);
  font-size: var(--text-base);
  font-weight: 600;
  margin-bottom: 4rpx;
}
.pair-date {
  display: block;
  font-size: var(--text-xs);
  color: var(--muted);
}

/* 阶段选择 */
.stage-section {
  margin-bottom: 64rpx;
}
.label {
  display: block;
  font-size: var(--text-sm);
  color: var(--muted);
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}
.stage-buttons {
  display: flex;
  gap: 16rpx;
}
.stage-buttons button {
  flex: 1;
  font-size: var(--text-sm);
  font-weight: 500;
  padding: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--r-full);
  background: var(--bg2);
  color: var(--muted);
  border: 1rpx solid var(--rule);
}
.stage-buttons button.active {
  background: var(--accent);
  color: var(--cta-text);
  border-color: var(--accent);
  font-weight: 600;
}
.stage-desc {
  display: block;
  font-size: var(--text-xs);
  color: var(--faint);
  padding-left: 8rpx;
  margin-top: 16rpx;
  line-height: 1.5;
}

/* 设置卡片 */
.settings-card {
  background: var(--bg-card);
  border: 1rpx solid var(--rule);
  border-radius: var(--r-lg);
  padding: 36rpx;
  margin-bottom: 24rpx;
}
.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 48rpx;
}
.settings-row + .settings-row {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--rule);
}
.settings-label {
  font-size: var(--text-base);
  color: var(--ink);
}
.settings-value {
  font-size: var(--text-sm);
  color: var(--muted);
}

/* 危险操作 */
.danger {
  margin-top: 56rpx;
}
.unbind-btn {
  display: block;
  width: 100%;
  height: 72rpx;
  border-radius: var(--r-full);
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent-light);
  font-size: var(--text-sm);
  line-height: 72rpx;
}
.unbind-hint {
  display: block;
  font-size: var(--text-xs);
  color: var(--faint);
  text-align: center;
  margin-top: 16rpx;
}
.unbind-confirm {
  margin-top: 24rpx;
}

/* 分级解绑选项 */
.unbind-options {
  margin-top: 24rpx;
}
.unbind-title {
  display: block;
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 24rpx;
  text-align: center;
}
.unbind-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--bg2);
  border-radius: var(--r-md);
  margin-bottom: 16rpx;
  border: 1rpx solid var(--rule);
}
.unbind-option-info {
  flex: 1;
}
.unbind-option-name {
  display: block;
  font-size: var(--text-base);
  font-weight: 500;
  color: var(--ink);
  margin-bottom: 4rpx;
}
.unbind-option-desc {
  display: block;
  font-size: var(--text-xs);
  color: var(--muted);
}
.unbind-cancel-btn {
  width: 100%;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--bg2);
  color: var(--muted);
  font-size: var(--text-base);
  line-height: var(--cta-height);
  border: 1rpx solid var(--rule);
  margin-top: 16rpx;
}
.unbind-warning-title {
  display: block;
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 16rpx;
  text-align: center;
}
.unbind-warning-text {
  display: block;
  color: var(--ink2);
  font-size: var(--text-sm);
  line-height: 1.8;
  margin-bottom: 32rpx;
}
.unbind-info-text {
  display: block;
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 16rpx;
  text-align: center;
}
.unbind-info-desc {
  display: block;
  color: var(--muted);
  font-size: var(--text-sm);
  line-height: 1.6;
  margin-bottom: 32rpx;
}
.unbind-confirm text {
  display: block;
  color: var(--ink2);
  font-size: var(--text-sm);
  line-height: 1.8;
  margin-bottom: 32rpx;
}
.confirm-buttons {
  display: flex;
  gap: 20rpx;
}
.confirm-buttons button {
  flex: 1;
  height: var(--cta-height);
  border-radius: var(--r-full);
  font-size: var(--text-base);
  font-weight: 500;
  line-height: var(--cta-height);
}
.confirm {
  background: var(--accent);
  color: var(--cta-text);
}
.confirm-buttons button:last-child {
  background: var(--surface-warm-bg);
  color: var(--surface-warm-text);
  border: 1rpx solid var(--rule);
}

.settings-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settings-arrow {
  font-size: var(--text-lg);
  color: var(--faint);
}

.switch {
  flex-shrink: 0;
}

.switch-track {
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: var(--bg2);
  border: 1rpx solid var(--rule);
  position: relative;
  transition: background 0.2s;
}

.switch-track.active {
  background: var(--accent);
  border-color: var(--accent);
}

.switch-thumb {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ffffff;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.2s;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.switch-thumb.active {
  transform: translateX(40rpx);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #ffffff;
  border-radius: var(--r-lg);
  padding: 40rpx;
}

.modal-title {
  display: block;
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--ink);
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-options {
  margin-bottom: 32rpx;
}

.modal-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: var(--r-md);
  background: var(--bg2);
  margin-bottom: 12rpx;
  font-size: var(--text-base);
  color: var(--ink);
}

.modal-option:last-child {
  margin-bottom: 0;
}

.modal-option.selected {
  background: var(--accent-lighter);
  color: var(--accent);
}

.option-check {
  color: var(--accent);
  font-weight: 600;
}

.modal-cancel {
  width: 100%;
  height: var(--cta-height);
  border-radius: var(--r-full);
  background: var(--bg2);
  color: var(--muted);
  font-size: var(--text-base);
  line-height: var(--cta-height);
  border: 1rpx solid var(--rule);
}