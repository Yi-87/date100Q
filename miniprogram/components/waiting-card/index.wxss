/* 等待卡片组件 */

.card {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--r-xl);
  padding: 80rpx 40rpx;
  text-align: center;
  border: 1rpx solid var(--rule);
  box-sizing: border-box;
}
.emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}
.title {
  display: block;
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 16rpx;
}
.dots {
  display: block;
  font-size: 48rpx;
  color: var(--accent-light);
  margin-bottom: 24rpx;
  min-height: 56rpx;
}
.hint {
  display: block;
  font-size: var(--text-xs);
  color: var(--faint);
  line-height: 1.5;
}