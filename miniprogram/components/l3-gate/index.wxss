/* L3 门禁组件 */

.gate {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--r-xl);
  padding: 64rpx 40rpx;
  text-align: center;
  border: 1rpx solid var(--rule);
  box-sizing: border-box;
}
.icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--accent-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}
.icon-text {
  font-size: 48rpx;
  color: var(--accent);
}
.title {
  display: block;
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 12rpx;
}
.desc {
  display: block;
  font-size: var(--text-sm);
  color: var(--muted);
  margin-bottom: 40rpx;
  line-height: 1.6;
}
.status {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  margin-bottom: 40rpx;
  font-size: var(--text-sm);
  color: var(--muted);
}
.gate-btn {
  background: var(--cta-bg);
  color: var(--cta-text);
  border-radius: var(--r-full);
  width: 400rpx;
  height: var(--cta-height);
  font-size: var(--text-base);
  font-weight: 500;
  line-height: var(--cta-height);
}
.waiting-text {
  margin-top: 16rpx;
}
.waiting-text-content {
  color: var(--muted);
  font-size: var(--text-sm);
}